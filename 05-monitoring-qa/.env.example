# Telegram Bot
TELEGRAM_TOKEN=

# LLM Provider (OpenRouter)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL=openai/gpt-oss-20b:free
MODEL_QUERY_TRANSFORM=openai/gpt-oss-20b:free
EMBEDDING_MODEL=text-embedding-3-large

# Data & Prompts
DATA_DIR=data
SYSTEM_PROMPT=Ты ассистент, отвечающий на вопросы по документам.
RETRIEVER_K=3

# LangSmith (опционально)
LANGSMITH_API_KEY=
LANGSMITH_TRACING_V2=false
LANGSMITH_PROJECT=05-rag-assistant
LANGSMITH_DATASET=05-rag-qa-dataset

# Features
SHOW_SOURCES=false
RAG_DEBUG=false

# RAGAS (модели для evaluation)
RAGAS_LLM_MODEL=gpt-4o
RAGAS_EMBEDDING_MODEL=text-embedding-3-large
